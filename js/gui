//index.js
// GUI MANAGER: The renderUI function
// This is the actual "Artist" that forces the HTML to change.
function renderUI() {
    // 1. UPDATE TEXT: Pushes P3 data into the HTML spans
    document.getElementById("h-pts").innerText = currentNode.humanPts;
    document.getElementById("c-pts").innerText = currentNode.compPts;

    // 2. TURN VISUALS: Adds CSS classes to the score boxes
    if (currentNode.whoseTurn === "human") {
        document.getElementById("h-box").classList.add("active-turn");
    } else {
        document.getElementById("c-box").classList.add("active-turn");
    }

    // 3. DYNAMIC BUTTONS: Wipes the screen and redraws buttons
    let grid = document.getElementById("button-grid");
    grid.innerHTML = ""; // CLEAR SCREEN
    
    currentNode.nums.forEach((val, index) => {
        let btn = document.createElement("button"); // CREATE ELEMENT
        btn.className = "number-btn"; // STYLE ELEMENT
        btn.innerText = val; // SET VALUE
        
        // GUI EVENT LINK: Connects physical click to the humanMove function
        btn.onclick = function() {
            humanMove(index); 
            renderUI(); // RE-RENDER GUI
        };
        grid.appendChild(btn); // ATTACH TO SCREEN
    });
}
